generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Situation {
  id          String     @id @default(cuid())
  metier      String
  categorie   String
  titre       String
  description String
  tags        String[]
  variantes   Variante[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Variante {
  id          String    @id @default(cuid())
  situationId String
  situation   Situation @relation(fields: [situationId], references: [id], onDelete: Cascade)
  label       String
  contenu     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
