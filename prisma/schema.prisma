generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id         String   @id @default(cuid())
  authUserId String   @unique
  email      String
  displayName String?
  metier     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Situation {
  id          String     @id @default(cuid())
  metier      String
  categorie   String
  titre       String
  description String
  tags        String[]
  favorites   Favorite[]
  variantes   Variante[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Favorite {
  id         String    @id @default(cuid())
  authUserId String
  situationId String
  situation  Situation @relation(fields: [situationId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([authUserId, situationId])
}

model Variante {
  id          String    @id @default(cuid())
  situationId String
  situation   Situation @relation(fields: [situationId], references: [id], onDelete: Cascade)
  label       String
  contenu     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
