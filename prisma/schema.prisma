generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String?
  metier       String
  favorites    Favorite[]
  sessions     Session[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Situation {
  id          String     @id @default(cuid())
  metier      String
  categorie   String
  titre       String
  description String
  tags        String[]
  favorites   Favorite[]
  variantes   Variante[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Favorite {
  id          String      @id @default(cuid())
  userId      String
  situationId String
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  situation   Situation   @relation(fields: [situationId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@unique([userId, situationId])
}

model Session {
  id        String      @id @default(cuid())
  tokenHash String      @unique
  userId    String
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime    @default(now())

  @@index([userId])
}

model Variante {
  id          String    @id @default(cuid())
  situationId String
  situation   Situation @relation(fields: [situationId], references: [id], onDelete: Cascade)
  label       String
  contenu     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}